{
  "name": "ai-terminal",
  "productName": "AI Terminal",
  "version": "0.1.0",
  "description": "Warp-like desktop terminal with OpenAI-compatible LLM assistance.",
  "author": "Doka-NT",
  "private": true,
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "package:mac": "npm run build && COPYFILE_DISABLE=1 electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests electron.vite.config.ts vitest.config.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.dokant.aiterminal",
    "productName": "AI Terminal",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/keytar/**/*",
      "node_modules/node-pty/**/*"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "npmRebuild": false,
    "nativeRebuilder": null,
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "pkg",
        "zip"
      ]
    },
    "pkg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
